# ── Production note ──────────────────────────────────────────────────────
# In production the .env holds ONLY these bootstrap keys:
#   NODE_ENV, SECRETS_SOURCE=aws, AWS_REGION, SECRET_NAME_APP, SECRET_NAME_IG
# Every other key below (PORT, DB_*, IG_BASE_URL, FRONTEND_ORIGIN,
# PUBLIC_BASE_URL, TRADINGVIEW_IPS, EMAIL_FROM, plus the sensitive values)
# lives as JSON keys inside the app secret in AWS Secrets Manager — main.ts
# merges the whole secret into process.env at boot. Edit the secret, then
# `pm2 restart trading_view_bot` to apply. See PROJECT_DOCUMENTATION.md §7.
# ─────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development
AWS_REGION=eu-west-2

# Use "local" for development without AWS credentials.
# Production must use AWS Secrets Manager (SECRETS_SOURCE=aws).
SECRETS_SOURCE=local

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=trading_view_bot
DB_USERNAME=trading_view_bot
DB_PASSWORD=trading_view_bot

IG_BASE_URL=https://demo-api.ig.com/gateway/deal
FRONTEND_ORIGIN=http://localhost:5173

# Parent domain the csrf_token cookie is scoped to, WITH the leading dot
# (e.g. .qubs.co.uk). Required whenever the portal and API are on different
# subdomains — the portal's JS can't read a host-only cookie set by the API
# host, so the X-CSRF-Token header never gets attached and every mutation
# 403s. Leave unset for local dev (same-host localhost needs no widening).
# Never set this to a public suffix like .co.uk — browsers reject it.
CSRF_COOKIE_DOMAIN=

# Comma-separated TradingView webhook source IPs (see PROJECT_DOCUMENTATION.md
# Section 5 Layer 3 for the current list — TradingView can change these,
# double-check before deploying). If unset, TradingViewIpGuard rejects every
# webhook request (fails closed) — the bot silently never trades, not a
# security hole, but it means signals go nowhere until this is set.
TRADINGVIEW_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7

# Public HTTPS URL of this backend (no trailing slash). Used only to build
# the webhook URL shown on the Settings page (`{PUBLIC_BASE_URL}/webhook/signal`)
# — paste that into TradingView's alert webhook field. Leave unset in local
# dev; must be the real domain in production or Settings shows a broken URL.
PUBLIC_BASE_URL=https://your-domain.com

# Verified SES sender identity. Sends are authorized via the EC2 instance's
# IAM role — no SES credentials are stored anywhere.
EMAIL_FROM=no-reply@your-domain.com

# Optional — only read by `pnpm seed`, and only on its very first run (skipped
# once any user already exists). Omit SEED_ADMIN_PASSWORD to get a
# random one-time temp password printed to the console instead. Never commit
# real values here — set them in your local .env only.
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

SECRET_NAME_IG=prod/trading-bot/ig
SECRET_NAME_APP=prod/trading-bot/app

# Dev-only: lets a logged-in portal user fire a manual test signal
# (POST /signal/test) straight through the real condition pipeline, without
# waiting for TradingView. Still executes real IG orders if IG_BASE_URL
# points at the live API rather than demo — leave this unset/false anywhere
# other than local dev. TestSignalsEnabledGuard fails closed (defaults false).
ENABLE_TEST_SIGNALS=false

# Local-only secrets (required when SECRETS_SOURCE=local; never commit real values)
IG_API_KEY=replace-me
IG_USERNAME=replace-me
IG_PASSWORD=replace-me
JWT_SECRET=replace-with-a-long-random-string
WEBHOOK_SECRET=replace-with-a-random-string
