{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm start:dev)",
      "Bash(pnpm build)",
      "Bash(pnpm test)",
      "Bash(pnpm test:cov)",
      "Bash(pnpm test:watch)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm format)",
      "Bash(pnpm audit:check)",
      "Bash(pnpm migration:generate)",
      "Bash(pnpm migration:run)",
      "Bash(pnpm migration:revert)",
      "Bash(pnpm seed)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./test/**)",
      "Edit(./*.json)",
      "Edit(./*.ts)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/secrets/**)",
      "Bash(curl:*)",
      "Bash(rm -rf:*)",
      "Bash(pnpm publish:*)",
      "Edit(./.env)",
      "Edit(./.env.*)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
